<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Task Manager App</title>
  <style>
    :root{--bg:#f4f7fb;--card:#ffffff;--accent:#2b6cb0;--danger:#e53e3e}
    *{box-sizing:border-box;font-family:Inter, system-ui, Arial, sans-serif}
    body{
      margin:0;
      background:linear-gradient(135deg,rgba(0,0,0,0.5) 0%,rgba(0,0,0,0.4) 100%),url('data:image/jpeg;base64,');
      background-size:cover;
      background-attachment:fixed;
      background-position:center;
      color:#fff;
      padding:24px;
      min-height:100vh
    }
    .container{max-width:900px;margin:0 auto}
    h1{margin-bottom:12px;color:#fff;text-shadow:0 2px 4px rgba(0,0,0,0.2)}
    .card{background:rgba(255,255,255,0.95);padding:16px;border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,0.1);margin-bottom:16px;backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.2)}
    label{display:block;margin-top:8px;font-weight:600;color:#222}
    h2{color:#222;text-shadow:0 1px 2px rgba(0,0,0,0.1)}
    input[type=text], textarea, #filterInput, #cityInput{width:100%;padding:8px;margin-top:6px;border:1px solid #dfe7ef;border-radius:6px}
    button{background:var(--accent);color:#fff;border:none;padding:8px 12px;border-radius:6px;cursor:pointer;margin-top:10px;font-weight:600;transition:all 0.3s ease}
    button:hover{transform:translateY(-2px);box-shadow:0 6px 16px rgba(0,0,0,0.2)}
    .controls{display:flex;gap:8px;align-items:center}
    .controls input{flex:1}
    .tasks .task{border:1px solid #e6eef8;padding:10px;border-radius:6px;margin-top:8px;display:flex;justify-content:space-between;align-items:center}
    .task .meta{max-width:78%}
    .task h3{margin:0;font-size:16px}
    .task p{margin:6px 0 0 0;color:#334155}
    .task .actions{display:flex;gap:8px}
    .btn-delete{background:var(--danger)}
    .weather{margin-top:10px;padding:8px;border-radius:6px;background:#f0f7ff;border:1px solid #d7e9ff}
    .small{font-size:14px;color:#475569}
  </style>
</head>
<body>
  <main class="container">
    <h1>Task Manager App</h1>

    <section class="card">
      <h2>Add Task</h2>
      <form id="taskForm" onsubmit="handleAddTask(event)">
        <label for="taskName">Task Name</label>
        <input type="text" id="taskName" required />

        <label for="taskDesc">Description</label>
        <textarea id="taskDesc" rows="3"></textarea>

        <button type="submit">Add Task</button>
      </form>
    </section>

    <section class="card">
      <h2>Tasks</h2>
      <div class="controls">
        <input id="filterInput" placeholder="Filter tasks by keyword" />
        <button id="showAllBtn">Show All</button>
      </div>
      <div id="tasksList" class="tasks"></div>
    </section>

    <section class="card">
      <h2>Weather</h2>
      <div class="weather-controls">
        <input id="cityInput" placeholder="Enter city name" />
        <button id="getWeatherBtn">Get Weather</button>
      </div>
      <div id="weatherResult" class="weather"></div>
    </section>

  </main>

  <script>
    /* Task Manager App - All in One */
    let tasks = [];

    // Elements
    const taskForm = document.getElementById('taskForm');
    const taskName = document.getElementById('taskName');
    const taskDesc = document.getElementById('taskDesc');
    const tasksList = document.getElementById('tasksList');
    const filterInput = document.getElementById('filterInput');
    const showAllBtn = document.getElementById('showAllBtn');
    const cityInput = document.getElementById('cityInput');
    const getWeatherBtn = document.getElementById('getWeatherBtn');
    const weatherResult = document.getElementById('weatherResult');

    // Load tasks from localStorage
    function loadTasks(){
      const raw = localStorage.getItem('tasks');
      if(raw){
        try{ tasks = JSON.parse(raw); }catch(e){ tasks = []; }
      }
    }

    // Save tasks
    function saveTasks(){
      localStorage.setItem('tasks', JSON.stringify(tasks));
    }

    // Render tasks (optionally provide a list)
    function renderTasks(list = tasks){
      tasksList.innerHTML = '';

      // Use map() as required — build DOM nodes from task objects
      const nodes = list.map(task => {
        const wrap = document.createElement('div');
        wrap.className = 'task';

        const meta = document.createElement('div');
        meta.className = 'meta';
        const h = document.createElement('h3');
        h.textContent = task.name;
        const p = document.createElement('p');
        p.textContent = task.description || '';
        meta.appendChild(h);
        meta.appendChild(p);

        const actions = document.createElement('div');
        actions.className = 'actions';

        const del = document.createElement('button');
        del.textContent = 'Delete';
        del.className = 'btn-delete';
        del.onclick = () => deleteTask(task.id);

        actions.appendChild(del);

        wrap.appendChild(meta);
        wrap.appendChild(actions);

        return wrap;
      });

      nodes.forEach(n => tasksList.appendChild(n));
    }

    // Add task handler — wired with onsubmit in HTML
    function handleAddTask(ev){
      ev.preventDefault(); // prevent page reload

      const name = taskName.value.trim();
      const description = taskDesc.value.trim();
      if(!name) return;

      const newTask = { id: Date.now(), name, description };
      tasks.push(newTask);
      saveTasks();
      renderTasks();

      taskForm.reset();
    }

    // Delete a task
    function deleteTask(id){
      tasks = tasks.filter(t => t.id !== id);
      saveTasks();
      renderTasks();
    }

    // Filter tasks
    function applyFilter(){
      const q = filterInput.value.trim().toLowerCase();
      if(!q){ renderTasks(); return; }
      const filtered = tasks.filter(t => (t.name + ' ' + (t.description||'')).toLowerCase().includes(q));
      renderTasks(filtered);
    }

    // Weather feature using Open-Meteo (no API key)
    async function getWeatherForCity(city){
      weatherResult.textContent = 'Loading...';
      try{
        // Geocoding
        const geoRes = await fetch(`https://geocoding-api.open-meteo.com/v1/search?name=${encodeURIComponent(city)}&count=1`);
        if(!geoRes.ok) throw new Error('Location lookup failed');
        const geo = await geoRes.json();
        if(!geo.results || geo.results.length === 0) throw new Error('City not found');
        const loc = geo.results[0];

        // Weather
        const wRes = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${loc.latitude}&longitude=${loc.longitude}&current_weather=true&temperature_unit=celsius`);
        if(!wRes.ok) throw new Error('Weather fetch failed');
        const w = await wRes.json();
        if(!w.current_weather) throw new Error('No weather data');

        weatherResult.innerHTML = `<div><strong>${loc.name}, ${loc.country}</strong></div><div class="small">Temperature: ${w.current_weather.temperature} °C</div>`;
      }catch(err){
        weatherResult.textContent = 'Error: ' + err.message;
      }
    }

    // Event wiring
    document.addEventListener('DOMContentLoaded', () => {
      loadTasks();
      renderTasks();

      filterInput.addEventListener('input', applyFilter);
      showAllBtn.addEventListener('click', () => { filterInput.value = ''; renderTasks(); });

      getWeatherBtn.addEventListener('click', () => {
        const city = cityInput.value.trim();
        if(!city) return;
        getWeatherForCity(city);
      });
    });

    // Expose handler used in HTML onsubmit
    window.handleAddTask = handleAddTask;
  </script>
</body>
</html>
